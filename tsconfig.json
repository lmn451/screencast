{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "node",
      "chrome"
    ],
    "skipLibCheck": true,
    "noEmit": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts",
    "tests/unit/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "coverage",
    "test-results"
  ]
}
