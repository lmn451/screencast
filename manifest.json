{
  "manifest_version": 3,
  "name": "CaptureCast",
  "description": "Simple, privacy-focused screen recording: This Tab, Window, or Entire Screen.",
  "version": "0.2.1",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "CaptureCast",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  /*
   * Permissions rationale:
   * - activeTab: Needed for injecting overlay into the user's active tab during recording
   * - scripting: Required for chrome.scripting.executeScript to inject overlay.js
   * - offscreen: Required for the offscreen document API used for headless recording
   * - tabCapture: Required for capturing specific tabs with chrome.tabCapture API
   * - notifications: Optional - requested only when needed for user alerts
   */
  "permissions": ["activeTab", "scripting", "offscreen", "tabCapture"],
  "optional_permissions": ["notifications"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  /*
   * Phase 6 audit: overlay.js is NOT web_accessible.
   * It's injected via chrome.scripting.executeScript which does NOT require web_accessible.
   * Keeping it accessible would be a security risk.
   * Removed from web_accessible_resources.
   */
  "web_accessible_resources": []
}