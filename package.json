{
  "name": "screencast-e2e",
  "type": "module",
  "private": true,
  "version": "0.2.1",
  "description": "Playwright E2E tests for CaptureCast stop feature",
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:machine": "pnpm exec tsx tests/unit/xstate-review.mjs",
    "lint": "eslint . --ext .js --ignore-path .eslintignore",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "e2e:stop": "playwright test tests/e2e/stop -c tests/e2e/playwright.config.ts",
    "e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "e2e:list": "playwright test -c tests/e2e/playwright.config.ts --list",
    "e2e:ci": "xvfb-run -a --server-args='-screen 0 1920x1080x24' pnpm run e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@types/chrome": "0.0.280",
    "@types/node": "20.17.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.1.0",
    "fake-indexeddb": "^6.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.55.0",
    "prettier": "^2.8.8",
    "tsx": "4.19.2",
    "typescript": "5.8.3",
    "xstate": "^5.31.0"
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd"
}
