{
  "name": "capturecast",
  "type": "module",
  "private": true,
  "version": "0.3.0",
  "description": "Privacy-focused screen recording extension",
  "scripts": {
    "build": "esbuild sw-entry.js --bundle --outfile=dist/background.bundle.js && esbuild sw-entry-offscreen.js --bundle --outfile=dist/offscreen.bundle.js",
    "test": "npx playwright test -c tests/e2e/playwright.config.ts",
    "test:google": "npx playwright test tests/e2e/record-and-save/google-test.spec.ts -c tests/e2e/playwright.config.ts",
    "test:yahoo": "npx playwright test tests/e2e/record-and-save/yahoo-test.spec.ts -c tests/e2e/playwright.config.ts",
    "lint": "eslint . --ext .js --ignore-path .eslintignore",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "esbuild": "^0.24.2",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.1.0",
    "playwright": "^1.55.0",
    "prettier": "^2.8.8"
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd"
}
