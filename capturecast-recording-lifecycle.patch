 src/messages.js                     |  8 +--
 src/services/recordingService.ts    | 70 ++++++++++++++++++------
 tests/unit/messages.test.js         | 18 ++++++-
 tests/unit/recordingMachine.test.js | 37 +++++++++++++
 tests/unit/recordingService.test.js | 83 +++++++++++++++++++++++++++++
 9 files changed, 218 insertions(+), 31 deletions(-)

