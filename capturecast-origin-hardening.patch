+-                                                              ▼                     └─────────┘
+-                                                      ┌──────────────┐
+-                                                      │              │
+-                                                      │   SAVING     │
+-                                                      │              │
+-                                                      │  - waiting   │
+-                                                      │    for data  │
+-                                                      │  - timeout   │
+-                                                      └───────┬──────┘
+-                                                              │
+-                           ┌───────────────────────────────────┼───────────────────────────────────┐
+-                           │                                   │                                   │
+-                           ▼                                   ▼                                   │
+-                    ┌──────────────┐                    ┌──────────────┐                    ┌──────────────┐
+-                    │              │                    │              │                    │              │
+-                    │    SAVED     │                    │  RECOVERABLE │                    │   FAILED     │
+-                    │              │                    │              │                    │              │
